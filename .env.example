NODE_ENV=development
PORT=5000
# Comma-separated if you need multiple frontends (local + Vercel preview)
CLIENT_URL=http://localhost:5173

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/nf-site?retryWrites=true&w=majority

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_REFRESH_EXPIRES_IN=7d

COOKIE_SECRET=change-me-cookie-secret-min-32-chars
REFRESH_TOKEN_COOKIE_NAME=refreshToken
# Production (cross-site Vercel FE↔BE): leave unset → SameSite=None + Secure
# COOKIE_SECURE=true
# COOKIE_SAME_SITE=none

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_IMAGE_FOLDER=nf-site-reports/images
CLOUDINARY_VIDEO_FOLDER=nf-site-reports/videos
CLOUDINARY_DOCUMENT_FOLDER=nf-site-reports/documents
CLOUDINARY_CAD_FOLDER=nf-site-reports/cad-drawings

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=NF Site Installation Report
SMTP_FROM_EMAIL=no-reply@nfsite.com

MAX_IMAGE_SIZE_MB=5
MAX_VIDEO_SIZE_MB=100

RESET_PASSWORD_TOKEN_EXPIRES_MIN=60

SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@nfsite.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_MOBILE=9999999999

# Aisensy WhatsApp — alerts when installer submits payment for approval
AISENSY_ENABLED=true
AISENSY_API_KEY=
AISENSY_CAMPAIGN_NAME=
AISENSY_TEMPLATE_NAME=installation_payment
AISENSY_TEMPLATE_PARAM_MODE=default
AISENSY_SOURCE=NF Site Installation Report
# station = attach signed checklist / checklist PDF from the station (default)
# signed_checklist | checklist | cad | env
AISENSY_MEDIA_SOURCE=station
# Optional fallback only when station has no PDF attached
AISENSY_MEDIA_URL=
AISENSY_MEDIA_FILENAME=notification.pdf
